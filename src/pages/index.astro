---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import DashboardImage from '../assets/grace/dashboard.png';
import GravityHeroImage from '../assets/grace/gravity-hero.png';
import PreviewImage from '../assets/grace/preview.png';

const pipelineSteps = [
	['Acquire', 'GRACE/GRACE-FO Level-2 GSM spherical harmonic coefficients'],
	['Correct', 'Low-degree replacement, GIA correction, and mean-field removal'],
	['Filter', 'De-striping, Gaussian/Fan/DDK routing, and HSAF experiments'],
	['Synthesize', 'Convert spherical harmonics to gridded EWH anomalies'],
	['Validate', 'Preview, basin averages, trends, and diagnostic products'],
];

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} image={GravityHeroImage} />
	</head>
	<body>
		<Header />
		<main class="home-shell">
			<section class="hero" aria-labelledby="hero-title">
				<div class="hero-copy">
					<p class="eyebrow">Satellite Gravity Field</p>
					<h1 id="hero-title">GRACE Level-2 Processing Workflow</h1>
					<p class="subtitle">From Level-2 GSM spherical harmonics to gridded EWH products</p>
					<p class="hero-text">
						Technical notes and reproducible workflow records for transforming GRACE and
						GRACE-FO Level-2 spherical harmonic solutions into physically consistent equivalent
						water height (EWH) products.
					</p>
					<div class="hero-actions">
						<a class="button primary" href="#pipeline">Explore the Pipeline -></a>
						<a class="button text" href="/blog/">Browse Articles -></a>
					</div>
				</div>
				<div class="hero-media" aria-hidden="true">
					<Image src={GravityHeroImage} width={1180} height={720} alt="" loading="eager" />
				</div>
			</section>

			<section class="pipeline-strip" id="pipeline" aria-label="Processing pipeline">
				<div class="pipeline-intro">
					<h2>Processing Pipeline</h2>
					<p>From Level-2 harmonics to gridded EWH products</p>
				</div>
				<div class="pipeline-flow">
					{
						pipelineSteps.map(([title, body], index) => (
							<article>
								<span class="step-icon">{index + 1}</span>
								<div>
									<p class="step-number">0{index + 1}</p>
									<h3>{title}</h3>
									<p>{body}</p>
								</div>
							</article>
						))
					}
					<span class="download-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24"><path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14" /></svg>
					</span>
				</div>
			</section>

			<section class="content-grid" aria-label="GRACE Level-2 blog sections">
				<div class="panel" id="data">
					<h2>Data Products</h2>
					<div class="media-row">
						<Image src={PreviewImage} width={148} height={148} alt="Gridded EWH preview" />
						<div>
							<h3>Gridded EWH</h3>
							<p>Monthly EWH anomalies on controlled grids with product metadata and diagnostics.</p>
							<a href="/blog/third-post/">Learn more -></a>
						</div>
					</div>
					<div class="media-row">
						<Image src={DashboardImage} width={148} height={148} alt="Mascon and pipeline dashboard" />
						<div>
							<h3>Mascon Comparison</h3>
							<p>Independent reference products for checking spatial patterns and basin series.</p>
							<a href="/blog/first-post/">Learn more -></a>
						</div>
					</div>
				</div>

				<div class="panel" id="methods">
					<h2>Filtering Notes</h2>
					<div class="method-row">
						<div class="mini-plot line-plot" aria-hidden="true"></div>
						<div>
							<h3>HSAF</h3>
							<p>Hankel-spectrum filtering for stripe suppression and signal preservation.</p>
							<a href="/blog/second-post/">Read notes -></a>
						</div>
					</div>
					<div class="method-row">
						<div class="mini-plot gaussian-plot" aria-hidden="true"></div>
						<div>
							<h3>Gaussian / Fan / DDK</h3>
							<p>Baseline filter families for reproducible comparison and product routing.</p>
							<a href="/blog/second-post/">Read notes -></a>
						</div>
					</div>
				</div>

				<div class="panel article-panel">
					<h2>Recent Articles</h2>
					<ul>
						{
							posts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>{post.data.title}</a>
									<span><FormattedDate date={post.data.pubDate} /></span>
								</li>
							))
						}
					</ul>
					<a class="all-link" href="/blog/">All articles -></a>
				</div>
			</section>

			<section class="closing-note">
				<blockquote>
					Good processing is transparent, testable, and reproducible.<br />
					<span>Workflow first, results follow.</span>
				</blockquote>
			</section>
		</main>
		<Footer />
	</body>
</html>
