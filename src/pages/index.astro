---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getBlogPath, paths, site } from '../data/site';
import DashboardImage from '../assets/grace/dashboard.png';
import GravityHeroImage from '../assets/grace/gravity-hero.png';
import PreviewImage from '../assets/grace/preview.png';

const lang = 'en';
const t = site[lang];
const h = t.home;
const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
const stepIcons = [
	'<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M8 27l13-6 6 6-6 13-4-9-9-4Z"/><path d="M27 9l12 12M32 4l12 12M18 18l12 12"/><path d="M31 21 21 31"/></svg>',
	'<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M12 13h24M12 24h24M12 35h24"/><circle cx="19" cy="13" r="4"/><circle cx="30" cy="24" r="4"/><circle cx="22" cy="35" r="4"/></svg>',
	'<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M8 16c8 0 8 16 16 16s8-16 16-16"/><path d="M10 34h28"/><path d="M32 10h8v8"/><path d="M40 10 29 21"/></svg>',
	'<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M10 12h28v24H10z"/><path d="M10 20h28M10 28h28M19 12v24M29 12v24"/><path d="M6 40h36"/></svg>',
	'<svg viewBox="0 0 48 48" aria-hidden="true"><path d="M14 25l7 7 14-17"/><path d="M24 7a17 17 0 1 0 0 34 17 17 0 0 0 0-34Z"/></svg>',
];
---

<!doctype html>
<html lang={t.langCode}>
	<head>
		<BaseHead title={t.title} description={t.description} image={GravityHeroImage} lang={lang} alternateHref={paths.zh.home} />
	</head>
	<body>
		<Header lang={lang} alternateHref={paths.zh.home} />
		<main class="home-shell">
			<section class="hero" aria-labelledby="hero-title">
				<div class="geo-labels" aria-hidden="true">
					<span class="lat lat-60">60°N</span>
					<span class="lat lat-30">30°N</span>
					<span class="lat lat-0">0°</span>
					<span class="lat lat-s30">30°S</span>
					<span class="lat lat-s60">60°S</span>
					<span class="lon lon-180">180°</span>
					<span class="lon lon-120">120°W</span>
					<span class="lon lon-60">60°W</span>
					<span class="lon lon-0">0°</span>
					<span class="lon lon-60e">60°E</span>
					<span class="lon lon-120e">120°E</span>
					<span class="lon lon-180e">180°</span>
				</div>
				<div class="hero-copy">
					<p class="eyebrow">{h.eyebrow}</p>
					<h1 id="hero-title">{h.title}</h1>
					<p class="subtitle">{h.subtitle}</p>
					<p class="hero-text">{h.text}</p>
					<div class="hero-actions">
						<a class="button primary" href="#pipeline">{h.primaryAction}</a>
						<a class="button ghost" href={paths.en.blog}>{h.secondaryAction}</a>
					</div>
				</div>
				<div class="hero-media" aria-hidden="true">
					<Image src={GravityHeroImage} width={1662} height={974} quality={92} alt="" loading="eager" />
				</div>
			</section>

			<section class="section-block pipeline-section" id="pipeline" aria-labelledby="pipeline-title">
				<div class="section-heading wide-heading">
					<p class="section-label">01</p>
					<h2 id="pipeline-title">{h.pipelineTitle}</h2>
					<p>{h.pipelineDetailIntro}</p>
				</div>
				<div class="pipeline-detail-grid">
					{h.pipelineSteps.map(([title, body], index) => {
						const detail = h.pipelineDetails[index];
						return (
							<details class="pipeline-detail-card" id={`step-${index + 1}`}>
								<summary>
									<span class="step-icon" set:html={stepIcons[index]}></span>
									<span class="summary-copy">
										<span>{String(index + 1).padStart(2, '0')}</span>
										<strong>{title}</strong>
										<small>{body}</small>
									</span>
									<span class="expand-mark">+</span>
								</summary>
								<div class="step-detail prose-card">
									<h3>Principle</h3>
									<p>{detail.principle}</p>
									<h3>Formula</h3>
									<div class="formula-block" set:html={detail.formulaHtml}></div>
									<h3>Configuration example</h3>
									<dl class="config-list">
										{detail.config.map(([key, value]) => (
											<>
												<dt>{key}</dt>
												<dd>{value}</dd>
											</>
										))}
									</dl>
									<h3>Quality checks</h3>
									<ul>{detail.checks.map((item) => <li>{item}</li>)}</ul>
								</div>
							</details>
						);
					})}
				</div>
			</section>

			<section class="section-grid" aria-label="GRACE Level-2 site sections">
				<div class="panel feature-panel" id="data">
					<div class="panel-title">
						<p class="section-label">02</p>
						<h2>{h.dataTitle}</h2>
						<p>{h.dataLead}</p>
					</div>
					<div class="feature-list">
						{h.dataCards.map((card, index) => (
							<article class="media-card">
								<Image src={index === 0 ? PreviewImage : DashboardImage} width={148} height={148} alt="" />
								<div>
									<h3>{card.title}</h3>
									<p>{card.text}</p>
									<a href={card.href}>{card.linkText}</a>
								</div>
							</article>
						))}
					</div>
				</div>

				<div class="panel method-panel" id="methods">
					<div class="panel-title">
						<p class="section-label">03</p>
						<h2>{h.methodTitle}</h2>
						<p>{h.methodLead}</p>
					</div>
					<div class="method-list">
						{h.methodCards.map((card, index) => (
							<article class="method-card">
								<div class:list={['mini-plot', index === 0 ? 'line-plot' : 'gaussian-plot']} aria-hidden="true"></div>
								<div>
									<h3>{card.title}</h3>
									<p>{card.text}</p>
									<a href="/blog/second-post/">{t.blog.read}</a>
								</div>
							</article>
						))}
					</div>
				</div>

				<div class="panel posts-panel">
					<div class="panel-title">
						<p class="section-label">04</p>
						<h2>{h.recentTitle}</h2>
						<p>{h.recentLead}</p>
					</div>
					<div class="compact-post-list">
						{posts.map((post) => (
							<a href={getBlogPath(lang, post.id)}>
								<span><FormattedDate date={post.data.pubDate} /></span>
								<strong>{post.data.title}</strong>
							</a>
						))}
					</div>
					<a class="all-link" href={paths.en.blog}>{h.allArticles}</a>
				</div>
			</section>

			<section class="release-band" aria-labelledby="release-title">
				<div>
					<h2 id="release-title">{h.releaseTitle}</h2>
					<p>{h.releaseText}</p>
				</div>
				<a class="button primary" href={paths.en.downloads}>{h.releaseAction}</a>
			</section>

			<section class="closing-note">
				<blockquote>
					{h.quote}<br />
					<span>{h.quoteSub}</span>
				</blockquote>
			</section>
		</main>
		<Footer lang={lang} />
		<script is:inline data-pipeline-accordion>
			document.querySelectorAll('.pipeline-detail-card').forEach((card) => {
				card.addEventListener('toggle', () => {
					if (!card.open) return;
					document.querySelectorAll('.pipeline-detail-card[open]').forEach((other) => {
						if (other !== card) other.removeAttribute('open');
					});
				});
			});
		</script>

	</body>
</html>
