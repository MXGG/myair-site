---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const pipelineSteps = [
	['Acquire', 'GRACE Level-1B spherical harmonics'],
	['Preprocess', 'De-striping, filtering of correlated errors'],
	['Synthesis', 'Convert to spatial grid (SH -> grid)'],
	['Post-process', 'Gaussian / Hankel filtering & scaling'],
	['Products', 'EWH, mascon, trends, basins, diagnostics'],
];

const recentArticles = [
	['Hankel filtering for GRACE Level-2: theory and practice', 'May 20, 2026'],
	['Understanding leakage and signal preservation', 'May 18, 2026'],
	['Path to consistent EWH units (mmEWH vs cmEWH)', 'May 15, 2026'],
	['HSAF experiments and adaptive filtering', 'May 12, 2026'],
	['From P4M6 harmonics to basin mass change', 'May 08, 2026'],
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="home-shell">
			<section class="hero" aria-labelledby="hero-title">
				<div class="hero-copy">
					<p class="eyebrow">Satellite Gravity Field</p>
					<h1 id="hero-title">GRACE Level-2 Processing Workflow</h1>
					<p class="subtitle">From spherical harmonics to gridded EWH products</p>
					<p class="hero-text">
						Notes, methods, and reproducible recipes for transforming GRACE Level-1B spherical
						harmonic solutions into physically-consistent, high-resolution equivalent water
						height (EWH) fields.
					</p>
					<div class="hero-actions">
						<a class="button primary" href="#pipeline">Explore the Pipeline -></a>
						<a class="button text" href="/blog/">Browse Articles -></a>
					</div>
				</div>
				<div class="hero-media" aria-hidden="true">
					<img src="/grace/gravity-hero.png" alt="" />
				</div>
			</section>

			<section class="pipeline-strip" id="pipeline" aria-label="Processing pipeline">
				<div class="pipeline-intro">
					<h2>Processing Pipeline</h2>
					<p>From L1B harmonics to gridded EWH products</p>
				</div>
				<div class="pipeline-flow">
					{
						pipelineSteps.map(([title, body], index) => (
							<article>
								<span class="step-icon">{index + 1}</span>
								<div>
									<p class="step-number">0{index + 1}</p>
									<h3>{title}</h3>
									<p>{body}</p>
								</div>
							</article>
						))
					}
					<span class="download-icon" aria-hidden="true">
						<svg viewBox="0 0 24 24"><path d="M12 3v12m0 0 5-5m-5 5-5-5M5 21h14" /></svg>
					</span>
				</div>
			</section>

			<section class="content-grid" aria-label="GRACE Level-2 blog sections">
				<div class="panel" id="data">
					<h2>Data Products</h2>
					<div class="media-row">
						<img src="/grace/preview.png" alt="Gridded EWH preview" />
						<div>
							<h3>Gridded EWH</h3>
							<p>Monthly EWH anomalies on 0.25 degree or 1 degree grids with uncertainty.</p>
							<a href="/blog/third-post/">Learn more -></a>
						</div>
					</div>
					<div class="media-row">
						<img src="/grace/dashboard.png" alt="Mascon and pipeline dashboard" />
						<div>
							<h3>Mascon Solutions</h3>
							<p>Leakage-reduced mascon products for mass change studies.</p>
							<a href="/blog/first-post/">Learn more -></a>
						</div>
					</div>
				</div>

				<div class="panel" id="methods">
					<h2>Filtering Notes</h2>
					<div class="method-row">
						<div class="mini-plot line-plot" aria-hidden="true"></div>
						<div>
							<h3>Hankel Filter</h3>
							<p>Optimized for minimizing leakage and preserving signal.</p>
							<a href="/blog/second-post/">Read notes -></a>
						</div>
					</div>
					<div class="method-row">
						<div class="mini-plot gaussian-plot" aria-hidden="true"></div>
						<div>
							<h3>Gaussian Smoothing</h3>
							<p>Control effective resolution and suppress high-degree noise.</p>
							<a href="/blog/second-post/">Read notes -></a>
						</div>
					</div>
				</div>

				<div class="panel article-panel">
					<h2>Recent Articles</h2>
					<ul>
						{
							recentArticles.map(([title, date]) => (
								<li>
									<a href="/blog/">{title}</a>
									<span>{date}</span>
								</li>
							))
						}
					</ul>
					<a class="all-link" href="/blog/">All articles -></a>
				</div>
			</section>

			<section class="closing-note">
				<blockquote>
					Good processing is transparent, testable, and reproducible.<br />
					<span>Workflow first, results follow.</span>
				</blockquote>
			</section>
		</main>
		<Footer />
	</body>
</html>
