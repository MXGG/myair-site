---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { paths, site } from '../data/site';

const lang = 'en';
const t = site[lang];
const d = t.downloads;
const releaseUrl = 'https://github.com/MXGG/myair-site/releases';
---

<!doctype html>
<html lang={t.langCode}>
	<head>
		<BaseHead title={`${d.title} | ${t.title}`} description={d.lead} lang={lang} alternateHref={paths.zh.downloads} />
	</head>
	<body>
		<Header lang={lang} alternateHref={paths.zh.downloads} />
		<main class="page-shell downloads-shell">
			<section class="page-hero compact downloads-hero">
				<p class="eyebrow">{d.eyebrow}</p>
				<h1>{d.title}</h1>
				<p>{d.lead}</p>
			</section>

			<section class="software-card" aria-labelledby="software-title">
				<div class="software-main">
					<p class="section-label">{d.versionLabel}</p>
					<h2 id="software-title">{d.cardTitle}</h2>
					<p>{d.cardText}</p>
					<div class="software-actions">
						<a class="button primary" href={releaseUrl}>{d.button}</a>
						<span>{d.releaseHint}</span>
					</div>
				</div>
				<div class="software-meta" aria-label="Software metadata">
					{d.meta.map(([key, value]) => (
						<div><span>{key}</span><strong>{value}</strong></div>
					))}
				</div>
			</section>

			<section class="download-feature-grid" aria-label="Software features">
				{d.features.map((feature) => (
					<article class="download-feature-card">
						<h3>{feature.title}</h3>
						<p>{feature.text}</p>
					</article>
				))}
			</section>
			<section class="faq-card" aria-labelledby="faq-title">
				<h2 id="faq-title">FAQ</h2>
				<details><summary>What information should I check before installing?</summary><p>Confirm the release version, supported Windows version, and whether the package is an installer or portable build.</p></details>
				<details><summary>Where are software packages hosted?</summary><p>The download button points to the project release page, where versioned packages and release notes can be collected in one place.</p></details>
			</section>
		</main>
		<Footer lang={lang} />
	</body>
</html>
