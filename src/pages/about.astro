---
import AboutHeroImage from '../assets/grace/dashboard.png';
import Layout from '../layouts/BlogPost.astro';
import { paths, site } from '../data/site';

const lang = 'en';
const t = site[lang];
---

<Layout
	lang={lang}
	title={t.about.title}
	description={t.about.description}
	pubDate={new Date('May 27 2026')}
	tags={['About', 'Workflow', 'Documentation']}
	heroImage={AboutHeroImage}
	alternateHref={paths.zh.about}
>
	{t.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}

	<section class="developer-profile" aria-labelledby="developer-title">
		<h2 id="developer-title">Developer information</h2>
		<p><strong>Developer:</strong> Solid Geophysics Group, National Gravity Laboratory, Huazhong University of Science and Technology.</p>
		<p><strong>Chinese affiliation:</strong> 华中科技大学 国家精密重力测量科学中心 固体地球物理组</p>
		<p><strong>Address:</strong> 1037 Luoyu Road, Hongshan District, Wuhan, Hubei, China</p>
		<p><strong>Email:</strong> <a href="mailto:lilx@hust.edu.cn">lilx@hust.edu.cn</a></p>
		<p>This site is maintained as a technical documentation and workflow record for GRACE/GRACE-FO Level-2 processing experiments.</p>
	</section>
</Layout>
