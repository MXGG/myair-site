---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { getBlogPath, paths, site } from '../../data/site';

const lang = 'en';
const t = site[lang];
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const [featured, ...rest] = posts;
const topics = Array.from(new Set(posts.flatMap((post) => post.data.tags ?? [])));
---

<!doctype html>
<html lang={t.langCode}>
	<head>
		<BaseHead title={`${t.blog.title} | ${t.title}`} description={t.blog.lead} lang={lang} alternateHref={paths.zh.blog} />
	</head>
	<body>
		<Header lang={lang} alternateHref={paths.zh.blog} />
		<main class="blog-shell">
			<nav class="breadcrumb" aria-label="Breadcrumb"><a href={paths.en.home}>Home</a><span>/</span><span>Blog</span></nav>
			<section class="page-hero compact">
				<p class="eyebrow">{t.blog.eyebrow}</p>
				<h1>{t.blog.title}</h1>
				<p>{t.blog.lead}</p>
			</section>

			<section class="blog-controls" aria-label="Filter articles by topic">
				<button class="filter-chip active" type="button" data-filter="all">All</button>
				{topics.map((topic) => <button class="filter-chip" type="button" data-filter={topic}>{topic}</button>)}
			</section>

			<section class="blog-layout" aria-label="Blog posts">
				<div class="blog-main">
					{featured && (
						<article class="featured-post" data-post-card data-tags={(featured.data.tags ?? []).join('|')}>
							<a href={getBlogPath(lang, featured.id)}>
								{featured.data.heroImage && <Image width={920} height={460} src={featured.data.heroImage} alt={`${featured.data.title} cover`} />}
								<div>
									<p class="section-label">{t.blog.featured}</p>
									<h2>{featured.data.title}</h2>
									<p>{featured.data.description}</p>
									<span><FormattedDate date={featured.data.pubDate} />{featured.data.readingMinutes && <> · {featured.data.readingMinutes} {t.blog.minutes}</>}</span>
								</div>
							</a>
						</article>
					)}

					<div class="article-list-heading">
						<h2>{t.blog.latest}</h2>
						<p data-filter-count>{posts.length} notes</p>
					</div>
					<div class="post-card-grid">
						{rest.map((post) => (
							<article class="post-card" data-post-card data-tags={(post.data.tags ?? []).join('|')}>
								<a href={getBlogPath(lang, post.id)}>
									{post.data.heroImage && <Image width={520} height={292} src={post.data.heroImage} alt={`${post.data.title} cover`} />}
									<div class="post-card-body">
										<div class="post-meta"><FormattedDate date={post.data.pubDate} />{post.data.readingMinutes && <span>{post.data.readingMinutes} {t.blog.minutes}</span>}</div>
										<h3>{post.data.title}</h3>
										<p>{post.data.description}</p>
										<div class="tag-list">{post.data.tags?.map((tag) => <span>{tag}</span>)}</div>
									</div>
								</a>
							</article>
						))}
					</div>
				</div>

				<aside class="blog-aside">
					<section class="aside-card">
						<h2>{t.blog.asideTitle}</h2>
						<p>{t.blog.asideText}</p>
					</section>
					<section class="aside-card">
						<h2>{t.blog.tagsTitle}</h2>
						<div class="tag-list">{topics.map((topic) => <span>{topic}</span>)}</div>
					</section>
					<section class="aside-card recommended-card">
						<h2>Recommended start</h2>
						<a href="/blog/first-post/">A reproducible GRACE Level-2 workflow</a>
						<a href="/blog/second-post/">Filter products as a graph</a>
					</section>
					<section class="aside-card">
						<h2>{t.blog.resourcesTitle}</h2>
						<div class="resource-links">
							<a href={paths.en.downloads}>{t.nav.downloads}</a>
							<a href={paths.en.rss}>{t.footer.rss}</a>
						</div>
					</section>
				</aside>
			</section>
		</main>
		<Footer lang={lang} />
		<script is:inline>
			const buttons = Array.from(document.querySelectorAll('[data-filter]'));
			const cards = Array.from(document.querySelectorAll('[data-post-card]'));
			const counter = document.querySelector('[data-filter-count]');
			buttons.forEach((button) => {
				button.addEventListener('click', () => {
					const filter = button.dataset.filter;
					buttons.forEach((item) => item.classList.toggle('active', item === button));
					let shown = 0;
					cards.forEach((card) => {
						const tags = (card.dataset.tags || '').split('|');
						const visible = filter === 'all' || tags.includes(filter);
						card.hidden = !visible;
						if (visible) shown += 1;
					});
					if (counter) counter.textContent = `${shown} notes`;
				});
			});
		</script>
	</body>
</html>
