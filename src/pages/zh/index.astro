---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { getBlogPath, paths, site } from '../../data/site';
import DashboardImage from '../../assets/grace/dashboard.png';
import GravityHeroImage from '../../assets/grace/gravity-hero.png';
import PreviewImage from '../../assets/grace/preview.png';

const lang = 'zh';
const t = site[lang];
const h = t.home;
const posts = (await getCollection('blogZh'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang={t.langCode}>
	<head>
		<BaseHead title={t.title} description={t.description} image={GravityHeroImage} lang={lang} alternateHref={paths.en.home} />
	</head>
	<body>
		<Header lang={lang} alternateHref={paths.en.home} />
		<main class="home-shell">
			<section class="hero" aria-labelledby="hero-title">
				<div class="hero-copy">
					<p class="eyebrow">{h.eyebrow}</p>
					<h1 id="hero-title">{h.title}</h1>
					<p class="subtitle">{h.subtitle}</p>
					<p class="hero-text">{h.text}</p>
					<div class="hero-actions">
						<a class="button primary" href="#pipeline">{h.primaryAction}</a>
						<a class="button ghost" href={paths.zh.blog}>{h.secondaryAction}</a>
					</div>
					<div class="hero-stats" aria-label="站点概览">
						{h.stats.map(([value, label]) => (
							<div>
								<strong>{value}</strong>
								<span>{label}</span>
							</div>
						))}
					</div>
				</div>
				<div class="hero-media" aria-hidden="true">
					<Image src={GravityHeroImage} width={1180} height={720} alt="" loading="eager" />
				</div>
			</section>

			<section class="section-block pipeline-section" id="pipeline" aria-labelledby="pipeline-title">
				<div class="section-heading">
					<p class="section-label">01</p>
					<h2 id="pipeline-title">{h.pipelineTitle}</h2>
					<p>{h.pipelineLead}</p>
				</div>
				<div class="pipeline-flow">
					{h.pipelineSteps.map(([title, body], index) => (
						<article>
							<span class="step-icon">{String(index + 1).padStart(2, '0')}</span>
							<h3>{title}</h3>
							<p>{body}</p>
						</article>
					))}
				</div>
			</section>

			<section class="section-grid" aria-label="GRACE Level-2 网站栏目">
				<div class="panel feature-panel" id="data">
					<div class="panel-title">
						<p class="section-label">02</p>
						<h2>{h.dataTitle}</h2>
						<p>{h.dataLead}</p>
					</div>
					<div class="feature-list">
						{h.dataCards.map((card, index) => (
							<article class="media-card">
								<Image src={index === 0 ? PreviewImage : DashboardImage} width={148} height={148} alt="" />
								<div>
									<h3>{card.title}</h3>
									<p>{card.text}</p>
									<a href={card.href}>{card.linkText}</a>
								</div>
							</article>
						))}
					</div>
				</div>

				<div class="panel method-panel" id="methods">
					<div class="panel-title">
						<p class="section-label">03</p>
						<h2>{h.methodTitle}</h2>
						<p>{h.methodLead}</p>
					</div>
					<div class="method-list">
						{h.methodCards.map((card, index) => (
							<article class="method-card">
								<div class:list={['mini-plot', index === 0 ? 'line-plot' : 'gaussian-plot']} aria-hidden="true"></div>
								<div>
									<h3>{card.title}</h3>
									<p>{card.text}</p>
									<a href="/zh/blog/second-post/">{t.blog.read}</a>
								</div>
							</article>
						))}
					</div>
				</div>

				<div class="panel posts-panel">
					<div class="panel-title">
						<p class="section-label">04</p>
						<h2>{h.recentTitle}</h2>
						<p>{h.recentLead}</p>
					</div>
					<div class="compact-post-list">
						{posts.map((post) => (
							<a href={getBlogPath(lang, post.id)}>
								<span><FormattedDate date={post.data.pubDate} /></span>
								<strong>{post.data.title}</strong>
							</a>
						))}
					</div>
					<a class="all-link" href={paths.zh.blog}>{h.allArticles}</a>
				</div>
			</section>

			<section class="release-band" aria-labelledby="release-title">
				<div>
					<h2 id="release-title">{h.releaseTitle}</h2>
					<p>{h.releaseText}</p>
				</div>
				<a class="button primary" href={paths.zh.downloads}>{h.releaseAction}</a>
			</section>

			<section class="closing-note">
				<blockquote>
					{h.quote}<br />
					<span>{h.quoteSub}</span>
				</blockquote>
			</section>
		</main>
		<Footer lang={lang} />
	</body>
</html>
