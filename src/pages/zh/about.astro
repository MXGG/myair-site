---
import AboutHeroImage from '../../assets/grace/dashboard.png';
import Layout from '../../layouts/BlogPost.astro';
import { paths, site } from '../../data/site';

const lang = 'zh';
const t = site[lang];
---

<Layout
	lang={lang}
	title={t.about.title}
	description={t.about.description}
	pubDate={new Date('May 27 2026')}
	tags={['关于', '处理流程', '文档']}
	heroImage={AboutHeroImage}
	alternateHref={paths.en.about}
>
	{t.about.paragraphs.map((paragraph) => <p>{paragraph}</p>)}

	<section class="developer-profile" aria-labelledby="developer-title">
		<h2 id="developer-title">开发者信息</h2>
		<p><strong>开发单位：</strong>华中科技大学 国家精密重力测量科学中心 固体地球物理组</p>
		<p><strong>英文名称：</strong>Huazhong University of Science and Technology, National Gravity Laboratory, Solid Geophysics</p>
		<p><strong>地址：</strong>武汉市洪山区珞喻路 1037 号</p>
		<p><strong>邮箱：</strong><a href="mailto:lilx@hust.edu.cn">lilx@hust.edu.cn</a></p>
		<p>本站作为 GRACE/GRACE-FO Level-2 数据处理实验、软件流程和技术笔记的文档入口维护。</p>
	</section>
</Layout>
