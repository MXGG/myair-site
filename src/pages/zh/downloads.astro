---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { paths, site } from '../../data/site';

const lang = 'zh';
const t = site[lang];
const d = t.downloads;
const releaseUrl = 'https://github.com/MXGG/myair-site/releases';
---

<!doctype html>
<html lang={t.langCode}>
	<head>
		<BaseHead title={`${d.title} | ${t.title}`} description={d.lead} lang={lang} alternateHref={paths.en.downloads} />
	</head>
	<body>
		<Header lang={lang} alternateHref={paths.en.downloads} />
		<main class="page-shell">
			<section class="page-hero compact">
				<p class="eyebrow">{d.eyebrow}</p>
				<h1>{d.title}</h1>
				<p>{d.lead}</p>
			</section>

			<section class="download-card" aria-labelledby="release-title">
				<div>
					<h2 id="release-title">{d.cardTitle}</h2>
					<p>{d.cardText}</p>
				</div>
				<a class="button primary" href={releaseUrl}>{d.button}</a>
			</section>

			<section class="note-grid" aria-label="发布说明">
				{d.notes.map((note) => (
					<article class="note-card">
						<h3>{note.title}</h3>
						<ul>{note.items.map((item) => <li>{item}</li>)}</ul>
					</article>
				))}
			</section>
		</main>
		<Footer lang={lang} />
	</body>
</html>
