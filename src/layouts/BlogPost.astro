---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import type { Lang } from '../data/site';
import { getAlternatePath, site } from '../data/site';

type BlogData = CollectionEntry<'blog'>['data'];
interface Props extends BlogData {
	lang?: Lang;
	slug?: string;
	alternateHref?: string;
}

const { title, description, pubDate, updatedDate, heroImage, tags = [], readingMinutes, lang = 'en', slug, alternateHref } = Astro.props;
const t = site[lang].blog;
const alt = alternateHref ?? (slug ? getAlternatePath(lang, 'blog', slug) : getAlternatePath(lang, 'blog'));
---

<html lang={site[lang].langCode}>
	<head>
		<BaseHead title={title} description={description} image={heroImage} lang={lang} alternateHref={alt} />
	</head>

	<body>
		<Header lang={lang} alternateHref={alt} />
		<main class="article-shell">
			<article class="article-frame">
				<header class="article-header">
					<div class="article-meta">
						<span><FormattedDate date={pubDate} /></span>
						{readingMinutes && <span>{readingMinutes} {t.minutes}</span>}
						{updatedDate && <span>Updated <FormattedDate date={updatedDate} /></span>}
					</div>
					<h1>{title}</h1>
					<p>{description}</p>
					{tags.length > 0 && (
						<div class="tag-list" aria-label="Article topics">
							{tags.map((tag) => <span>{tag}</span>)}
						</div>
					)}
				</header>

				{heroImage && (
					<div class="hero-image">
						<Image width={1120} height={560} src={heroImage} alt="" />
					</div>
				)}

				<div class="prose article-prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer lang={lang} />
	</body>
</html>
