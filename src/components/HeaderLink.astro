---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const hrefString = String(href ?? '');
const hasHash = hrefString.includes('#');
const hrefPath = hrefString.split('#')[0] || '/';
const normalizedHref = hrefPath.endsWith('/') ? hrefPath : `${hrefPath}/`;
const normalizedPath = pathname.endsWith('/') ? pathname : `${pathname}/`;
const isActive = !hasHash && (normalizedHref === normalizedPath || (normalizedHref !== '//' && normalizedHref !== '/' && normalizedPath.startsWith(normalizedHref)));
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
