---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/" aria-label={`${SITE_TITLE} home`}>
			<span class="brand-mark" aria-hidden="true"></span>
			<span>{SITE_TITLE}</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 10;
		border-bottom: 1px solid rgba(27, 39, 56, 0.1);
		background: rgba(248, 251, 253, 0.88);
		backdrop-filter: blur(16px);
	}

	nav {
		display: flex;
		width: min(1180px, calc(100% - 40px));
		min-height: 72px;
		margin: 0 auto;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: var(--ink);
		font-size: 0.98rem;
		font-weight: 700;
		text-decoration: none;
		letter-spacing: 0;
	}

	.brand-mark {
		width: 18px;
		height: 18px;
		border: 2px solid var(--accent);
		border-radius: 50%;
		box-shadow: inset 0 0 0 4px var(--paper), 0 0 0 1px rgba(14, 116, 144, 0.18);
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 4px;
		font-size: 0.88rem;
	}

	nav a {
		padding: 0.65rem 0.78rem;
		color: var(--muted);
		text-decoration: none;
		border-bottom: 2px solid transparent;
	}

	nav a:hover,
	nav a.active {
		color: var(--ink);
	}

	nav a.active {
		border-bottom-color: var(--accent);
	}

	@media (max-width: 640px) {
		nav {
			width: min(330px, calc(100% - 28px));
			max-width: 330px;
			min-height: 64px;
			gap: 10px;
			justify-content: flex-start;
		}

		.brand {
			gap: 8px;
			font-size: 0.86rem;
			white-space: nowrap;
		}

		.brand-mark {
			width: 16px;
			height: 16px;
		}

		.internal-links {
			display: none;
		}

		nav a {
			padding: 0.55rem 0.34rem;
		}
	}
</style>
