---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/">{SITE_TITLE}</a>
		<div class="internal-links" aria-label="Primary navigation">
			<HeaderLink href="/#pipeline">Pipeline</HeaderLink>
			<HeaderLink href="/#data">Data</HeaderLink>
			<HeaderLink href="/#methods">Methods</HeaderLink>
			<HeaderLink href="/blog/">Blog</HeaderLink>
			<HeaderLink href="/downloads/">Downloads</HeaderLink>
			<HeaderLink href="/about/">About</HeaderLink>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		height: 60px;
		border-bottom: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.94);
		backdrop-filter: blur(16px);
	}

	nav {
		display: flex;
		width: min(1400px, calc(100% - 96px));
		height: 60px;
		margin: 0 auto;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}

	.brand {
		color: var(--ink);
		font-size: 1.35rem;
		font-weight: 700;
		line-height: 1;
		text-decoration: none;
		white-space: nowrap;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 24px;
		margin-left: auto;
		font-size: 0.9rem;
	}

	nav a {
		color: var(--ink);
		text-decoration: none;
	}

	nav a:hover,
	nav a.active {
		color: var(--accent-strong);
	}

	@media (max-width: 900px) {
		nav {
			width: calc(100% - 32px);
		}

		.internal-links {
			gap: 16px;
			font-size: 0.84rem;
		}
	}

	@media (max-width: 760px) {
		nav {
			width: calc(100% - 28px);
		}

		.internal-links {
			display: none;
		}

		.brand {
			font-size: 1rem;
		}
	}
</style>
