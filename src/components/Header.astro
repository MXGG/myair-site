---
import type { Lang } from '../data/site';
import { paths, site } from '../data/site';
import HeaderLink from './HeaderLink.astro';

interface Props {
	lang?: Lang;
	alternateHref?: string;
}

const { lang = 'en', alternateHref = paths.zh.home } = Astro.props;
const t = site[lang];
const p = paths[lang];
const links = [
	{ href: p.home, label: t.nav.home },
	{ href: p.pipeline, label: t.nav.pipeline },
	{ href: p.data, label: t.nav.data },
	{ href: p.methods, label: t.nav.methods },
	{ href: p.blog, label: t.nav.blog },
	{ href: p.downloads, label: t.nav.downloads },
	{ href: p.about, label: t.nav.about },
];
---

<header class="site-header">
	<nav class="site-nav" aria-label="Primary navigation">
		<a class="brand" href={p.home} aria-label={`${t.title} ${t.nav.home}`}>
			<span class="brand-mark" aria-hidden="true">G</span>
			<span>{t.title}</span>
		</a>

		<div class="desktop-links" aria-label="Primary navigation links">
			{links.map((link) => <HeaderLink href={link.href}>{link.label}</HeaderLink>)}
		</div>

		<a class="language-switch" href={alternateHref} hreflang={lang === 'en' ? 'zh-CN' : 'en'}>
			{t.nav.switch}
		</a>

		<details class="mobile-menu">
			<summary aria-label={t.nav.menu}>
				<span>{t.nav.menu}</span>
				<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
			</summary>
			<div class="mobile-menu-panel">
				{links.map((link) => <HeaderLink href={link.href}>{link.label}</HeaderLink>)}
				<a class="mobile-language" href={alternateHref} hreflang={lang === 'en' ? 'zh-CN' : 'en'}>
					{t.nav.switch}
				</a>
			</div>
		</details>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 50;
		border-bottom: 1px solid var(--line-soft);
		background: rgba(255, 255, 255, 0.9);
		backdrop-filter: blur(18px);
	}

	.site-nav {
		display: flex;
		width: min(var(--container-wide), calc(100% - 48px));
		height: 64px;
		margin: 0 auto;
		align-items: center;
		gap: 22px;
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: var(--ink);
		font-weight: 760;
		letter-spacing: -0.02em;
		text-decoration: none;
		white-space: nowrap;
	}

	.brand-mark {
		display: inline-grid;
		width: 32px;
		height: 32px;
		place-items: center;
		border: 1px solid rgba(15, 111, 157, 0.24);
		border-radius: 9px;
		background: linear-gradient(145deg, rgba(15, 111, 157, 0.16), rgba(255, 255, 255, 0.9));
		color: var(--accent-strong);
		font-size: 0.94rem;
	}

	.desktop-links {
		display: flex;
		align-items: center;
		gap: 20px;
		margin-left: auto;
		font-size: 0.9rem;
	}

	.desktop-links a,
	.mobile-menu-panel a,
	.language-switch {
		color: var(--text);
		text-decoration: none;
		transition: color 160ms ease, background-color 160ms ease, transform 160ms ease;
	}

	.desktop-links a:hover,
	.desktop-links a.active,
	.mobile-menu-panel a:hover,
	.mobile-menu-panel a.active {
		color: var(--accent-strong);
	}

	.desktop-links a.active {
		font-weight: 740;
	}

	.language-switch {
		display: inline-flex;
		min-height: 34px;
		align-items: center;
		justify-content: center;
		padding: 0 12px;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.74);
		font-size: 0.86rem;
		font-weight: 700;
		white-space: nowrap;
	}

	.language-switch:hover {
		background: var(--blue-soft);
		color: var(--accent-strong);
		transform: translateY(-1px);
	}

	.mobile-menu {
		display: none;
		position: relative;
		margin-left: auto;
	}

	.mobile-menu summary {
		display: inline-flex;
		min-height: 38px;
		align-items: center;
		gap: 8px;
		padding: 0 12px;
		border: 1px solid var(--line);
		border-radius: 999px;
		background: white;
		color: var(--ink);
		cursor: pointer;
		font-size: 0.88rem;
		font-weight: 700;
		list-style: none;
	}

	.mobile-menu summary::-webkit-details-marker {
		display: none;
	}

	.mobile-menu svg {
		width: 18px;
		height: 18px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-width: 2;
	}

	.mobile-menu-panel {
		position: absolute;
		right: 0;
		top: calc(100% + 12px);
		display: grid;
		min-width: min(320px, calc(100vw - 28px));
		padding: 10px;
		border: 1px solid var(--line);
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.98);
		box-shadow: var(--shadow);
		gap: 2px;
	}

	.mobile-menu-panel a {
		padding: 11px 12px;
		border-radius: 10px;
		font-weight: 700;
	}

	.mobile-menu-panel a:hover,
	.mobile-menu-panel a.active {
		background: var(--blue-soft);
	}

	.mobile-language {
		margin-top: 6px;
		border-top: 1px solid var(--line-soft);
	}

	@media (max-width: 980px) {
		.site-nav {
			width: calc(100% - 28px);
		}

		.desktop-links,
		.language-switch {
			display: none;
		}

		.mobile-menu {
			display: block;
		}
	}

	@media (max-width: 420px) {
		.brand span:last-child {
			max-width: 180px;
			overflow: hidden;
			text-overflow: ellipsis;
		}
	}
</style>
