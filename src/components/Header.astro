---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a class="brand" href="/">{SITE_TITLE}</a>
		<div class="internal-links">
			<HeaderLink href="/#pipeline">Pipeline</HeaderLink>
			<HeaderLink href="/#data">Data</HeaderLink>
			<HeaderLink href="/#methods">Methods</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
		</div>
		<div class="tools" aria-label="Display tools">
			<span aria-hidden="true">
				<svg viewBox="0 0 24 24"><path d="m21 21-4.3-4.3m2.3-5.2a7.5 7.5 0 1 1-15 0 7.5 7.5 0 0 1 15 0Z" /></svg>
			</span>
			<span aria-hidden="true">
				<svg viewBox="0 0 24 24"><path d="M12 4V2m0 20v-2m8-8h2M2 12h2m13.7-5.7 1.4-1.4M4.9 19.1l1.4-1.4m0-11.4L4.9 4.9m14.2 14.2-1.4-1.4M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z" /></svg>
			</span>
		</div>
	</nav>
</header>

<style>
	header {
		position: sticky;
		top: 0;
		z-index: 20;
		height: 60px;
		border-bottom: 1px solid var(--line);
		background: rgba(255, 255, 255, 0.94);
		backdrop-filter: blur(16px);
	}

	nav {
		display: flex;
		width: min(1400px, calc(100% - 96px));
		height: 60px;
		margin: 0 auto;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
	}

	.brand {
		color: var(--ink);
		font-size: 1.35rem;
		font-weight: 700;
		line-height: 1;
		text-decoration: none;
		white-space: nowrap;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 28px;
		margin-left: auto;
		font-size: 0.9rem;
	}

	nav a {
		color: var(--ink);
		text-decoration: none;
	}

	nav a:hover,
	nav a.active {
		color: var(--accent-strong);
	}

	.tools {
		display: flex;
		gap: 20px;
		margin-left: 22px;
		color: var(--ink);
	}

	.tools span {
		display: inline-flex;
		width: 22px;
		height: 22px;
		align-items: center;
		justify-content: center;
	}

	.tools svg {
		width: 19px;
		height: 19px;
		fill: none;
		stroke: currentColor;
		stroke-linecap: round;
		stroke-linejoin: round;
		stroke-width: 2;
	}

	@media (max-width: 760px) {
		nav {
			width: calc(100% - 28px);
		}

		.internal-links,
		.tools {
			display: none;
		}

		.brand {
			font-size: 1rem;
		}
	}
</style>
