---
import type { Lang } from '../data/site';
import { paths, site } from '../data/site';

interface Props {
	lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const today = new Date();
const t = site[lang];
const p = paths[lang];
---

<footer class="site-footer">
	<div class="footer-brand">
		<strong>{t.title}</strong>
		<p>{t.footer.summary}</p>
		<div class="developer-block">
			<span>{t.footer.developerLabel}</span>
			<p>{t.footer.developerZh}</p>
			<p>{t.footer.developerEn}</p>
			<p>{t.footer.address}</p>
			<a href="mailto:lilx@hust.edu.cn">lilx@hust.edu.cn</a>
		</div>
	</div>
	<div class="footer-links" aria-label={t.footer.sections}>
		<span>{t.footer.sections}</span>
		<a href={p.home}>{t.nav.home}</a>
		<a href={p.pipeline}>{t.nav.pipeline}</a>
		<a href={p.blog}>{t.nav.blog}</a>
		<a href={p.downloads}>{t.nav.downloads}</a>
		<a href={p.about}>{t.nav.about}</a>
	</div>
	<div class="footer-links" aria-label={t.footer.resources}>
		<span>{t.footer.resources}</span>
		<a href={p.rss}>{t.footer.rss}</a>
		<a href="https://github.com/MXGG/myair-site/releases">{t.footer.releases}</a>
		<a href="https://myair.info/">{t.footer.domain}</a>
	</div>
	<p class="copyright">&copy; {today.getFullYear()} {t.footer.copyright}</p>
</footer>

<style>
	.site-footer {
		display: grid;
		width: min(var(--container-xl), calc(100% - 64px));
		margin: 0 auto;
		padding: 58px 0 72px;
		grid-template-columns: minmax(420px, 1.1fr) auto auto;
		gap: 54px;
		border-top: 1px solid var(--line-soft);
		color: var(--muted);
		font-size: 0.96rem;
	}

	.footer-brand {
		display: grid;
		gap: 12px;
		max-width: 760px;
	}

	.footer-brand > strong {
		color: var(--ink);
		font-size: 1.08rem;
	}

	.developer-block {
		display: grid;
		gap: 4px;
		margin-top: 12px;
		padding: 18px;
		border: 1px solid var(--line-soft);
		border-radius: 18px;
		background: color-mix(in srgb, var(--surface) 78%, transparent);
	}

	.developer-block span,
	.footer-links span {
		color: var(--ink);
		font-weight: 760;
	}

	.developer-block p {
		margin: 0;
		line-height: 1.65;
	}

	.developer-block a,
	.footer-links a {
		color: var(--muted);
	}

	.developer-block a:hover,
	.footer-links a:hover {
		color: var(--accent-strong);
	}

	.footer-links {
		display: grid;
		gap: 8px;
		align-content: start;
	}

	.copyright {
		grid-column: 1 / -1;
		padding-top: 16px;
		border-top: 1px solid var(--line-soft);
		font-size: 0.86rem;
	}

	@media (max-width: 920px) {
		.site-footer {
			width: min(100% - 32px, var(--container));
			grid-template-columns: 1fr 1fr;
			gap: 30px;
			padding: 44px 0 56px;
		}

		.footer-brand {
			grid-column: 1 / -1;
			max-width: none;
		}
	}

	@media (max-width: 560px) {
		.site-footer {
			width: min(100% - 28px, var(--container));
			grid-template-columns: 1fr;
		}
	}
</style>
