---
const today = new Date();
---

<footer>
	<div>
		<strong>GRACE L2 Notes</strong>
		<span>Processing notes, filter comparisons, and reproducible workflow records.</span>
	</div>
	<p>&copy; {today.getFullYear()} myair.info</p>
</footer>

<style>
	footer {
		display: flex;
		width: min(1180px, calc(100% - 40px));
		margin: 0 auto;
		padding: 56px 0 72px;
		align-items: flex-start;
		justify-content: space-between;
		gap: 24px;
		border-top: 1px solid rgba(27, 39, 56, 0.1);
		color: var(--muted);
		font-size: 0.92rem;
	}

	footer div {
		display: grid;
		gap: 6px;
	}

	footer strong {
		color: var(--ink);
	}

	footer p {
		margin: 0;
	}

	@media (max-width: 640px) {
		footer {
			width: min(100% - 28px, 1180px);
			flex-direction: column;
			padding: 38px 0 56px;
		}
	}
</style>
